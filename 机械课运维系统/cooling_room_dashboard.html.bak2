            });
        }

        // 生成设备多Y轴数据
        function generateEquipmentMultiAxisData(equipmentType, startTime, endTime, granularity) {
            const data = [];
            const current = new Date(startTime);
            
            // 设备基础参数
            const equipmentParams = {
                'chiller': {
                    powerRange: [280, 360],
                    ratioRange: [60, 70],
                    copRange: [4.5, 6.0]
                },
                'chilled-pump': {
                    powerRange: [70, 100],
                    ratioRange: [15, 20],
                    copRange: [18, 22]
                },
                'cooling-pump': {
                    powerRange: [35, 55],
                    ratioRange: [8, 12],
                    copRange: [35, 43]
                },
                'cooling-tower': {
                    powerRange: [30, 50],
                    ratioRange: [7, 11],
                    copRange: [38, 46]
                }
            };
            
            const params = equipmentParams[equipmentType] || equipmentParams['chiller'];
            
            while (current <= endTime) {
                const hour = current.getHours();
                const dayOfWeek = current.getDay();
                
                // 时间因子（工作时间负荷更高）
                const timeFactor = (hour >= 8 && hour <= 18 && dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.2 : 0.8;
                
                // 季节因子
                const month = current.getMonth();
                const seasonFactor = (month >= 5 && month <= 8) ? 1.3 : 0.9; // 夏季负荷更高
                
                // 随机波动
                const randomFactor = 0.85 + Math.random() * 0.3;
                
                // 计算功率
                const basePower = (params.powerRange[0] + params.powerRange[1]) / 2;
                const power = basePower * timeFactor * seasonFactor * randomFactor;
                
                // 计算占比（相对稳定，小幅波动）
                const baseRatio = (params.ratioRange[0] + params.ratioRange[1]) / 2;
                const ratio = baseRatio + (Math.random() - 0.5) * 3;
                
                // 计算性能系数（与负荷相关）
                const baseCOP = (params.copRange[0] + params.copRange[1]) / 2;
                const loadFactor = power / ((params.powerRange[0] + params.powerRange[1]) / 2);
                const cop = baseCOP * (0.8 + loadFactor * 0.4) + (Math.random() - 0.5) * 0.5;
                
                data.push({
                    time: new Date(current),
                    power: Math.round(power * 10) / 10,
                    ratio: Math.round(ratio * 10) / 10,
                    cop: Math.round(cop * 100) / 100
                });
                
                current.setTime(current.getTime() + granularity * 60 * 1000);
            }
            
            return data;
        }

        // 更新系统能效指标图表
        function updateSystemEfficiencyChart() {
            const startDate = document.getElementById('system-efficiency-start-date').value;
            const endDate = document.getElementById('system-efficiency-end-date').value;
            const granularity = parseInt(document.getElementById('system-efficiency-data-granularity').value);
            
            if (!startDate || !endDate) {
