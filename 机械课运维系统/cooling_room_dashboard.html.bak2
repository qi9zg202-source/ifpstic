        // 更新时间范围信息
        function updateComprehensiveTimeRangeInfo() {
            const startDate = document.getElementById('comprehensive-start-date').value;
            const endDate = document.getElementById('comprehensive-end-date').value;
            const granularity = parseInt(document.getElementById('comprehensive-data-granularity').value);
            
            if (startDate && endDate) {
                const start = new Date(startDate);
                const end = new Date(endDate);
                const diffMs = end - start;
                const diffHours = diffMs / (1000 * 60 * 60);
                const diffDays = Math.round(diffHours / 24 * 10) / 10;
                
                const dataPoints = Math.ceil(diffMs / (granularity * 60 * 1000));
                
                let timeSpanText = '';
                if (diffHours < 24) {
                    timeSpanText = `${Math.round(diffHours * 10) / 10}小时`;
                } else {
                    timeSpanText = `${diffDays}天`;
                }
                
                let infoText = `时间跨度: ${timeSpanText}, 预计数据点: ${dataPoints}个`;
                let infoColor = '#28a745';
                
                if (dataPoints > 1000) {
                    infoText += ' (数据量较大，建议调整粒度)';
                    infoColor = '#ffc107';
                }
                if (dataPoints > 5000) {
                    infoText += ' ⚠️';
                    infoColor = '#dc3545';
                }
                
                const infoElement = document.getElementById('comprehensive-time-range-info');
                infoElement.textContent = infoText;
                infoElement.style.color = infoColor;
            }
        }

        // 生成综合能效指标数据
        function generateComprehensiveEfficiencyData(startTime, endTime, granularity) {
            const data = [];
            const current = new Date(startTime);
            
            // 基础参数
            let cumulativeCooling = 2800; // 起始累计制冷量 GJ
            let cumulativePower = 156000; // 起始累计电量 kWh
            
            while (current <= endTime) {
                const hour = current.getHours();
                const dayOfWeek = current.getDay();
                const month = current.getMonth();
                
                // 时间因子（工作时间负荷更高）
                const timeFactor = (hour >= 8 && hour <= 18 && dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.2 : 0.8;
                
                // 季节因子（夏季负荷更高）
                const seasonFactor = (month >= 5 && month <= 8) ? 1.3 : 0.9;
                
                // 随机波动
                const randomFactor = 0.9 + Math.random() * 0.2;
                
                // 计算增量（根据粒度调整）
                const timeIncrement = granularity / 60; // 小时数
                
                // 制冷量增量 (平均14MW制冷功率)
                const coolingIncrement = 14 * timeIncrement * timeFactor * seasonFactor * randomFactor * 3.6 / 1000; // GJ
                cumulativeCooling += coolingIncrement;
                
                // 电量增量 (平均500kW功率)
                const powerIncrement = 500 * timeIncrement * timeFactor * seasonFactor * randomFactor; // kWh
                cumulativePower += powerIncrement;
                
                // 计算瞬时EER (制冷量/电功率)
                const instantCoolingPower = coolingIncrement / timeIncrement * 1000 / 3.6; // kW
                const instantElectricPower = powerIncrement / timeIncrement; // kW
                const eer = instantCoolingPower / instantElectricPower;
                
                // 添加一些现实的EER波动
                const eerWithVariation = Math.max(2.5, Math.min(4.5, eer + (Math.random() - 0.5) * 0.5));
                
                data.push({
                    time: new Date(current),
                    cumulativeCooling: Math.round(cumulativeCooling * 10) / 10,
                    cumulativePower: Math.round(cumulativePower),
                    eer: Math.round(eerWithVariation * 100) / 100
                });
                
                current.setTime(current.getTime() + granularity * 60 * 1000);
            }
            
            return data;
        }

