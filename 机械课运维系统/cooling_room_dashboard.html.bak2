                    title: {
                        text: '时间'
                    }
                },
                yAxis: [{
                    // 第一个Y轴 - 功率
                    title: {
                        text: '功率 (kW)',
                        style: {
                            color: '#007bff'
                        }
                    },
                    labels: {
                        style: {
                            color: '#007bff'
                        }
                    },
                    opposite: false
                }, {
                    // 第二个Y轴 - 占比
                    title: {
                        text: '占比 (%)',
                        style: {
                            color: '#28a745'
                        }
                    },
                    labels: {
                        style: {
                            color: '#28a745'
                        }
                    },
                    opposite: true
                }, {
                    // 第三个Y轴 - 性能系数
                    title: {
                        text: '性能系数',
                        style: {
                            color: '#fd7e14'
                        }
                    },
                    labels: {
                        style: {
                            color: '#fd7e14'
                        }
                    },
                    opposite: true,
                    offset: 60
                }],
                tooltip: {
                    shared: true,
                    formatter: function() {
                        let tooltip = '<b>' + Highcharts.dateFormat('%Y-%m-%d %H:%M', this.x) + '</b><br/>';
                        this.points.forEach(function(point) {
                            let unit = '';
                            if (point.series.name.includes('功率')) unit = ' kW';
                            else if (point.series.name.includes('占比')) unit = '%';
                            tooltip += '<span style="color:' + point.color + '">' + point.series.name + '</span>: <b>' + point.y + unit + '</b><br/>';
                        });
                        return tooltip;
                    }
                },
                legend: {
                    enabled: true,
                    align: 'center',
                    verticalAlign: 'bottom'
                },
                plotOptions: {
                    spline: {
                        marker: {
                            enabled: false,
                            states: {
                                hover: {
                                    enabled: true,
                                    radius: 5
                                }
                            }
                        },
                        lineWidth: 2
                    }
                },
                series: [{
                    name: '功率(kW)',
                    data: times.map((time, index) => [time.getTime(), powerData[index]]),
                    color: '#007bff',
                    yAxis: 0
                }, {
                    name: '占比(%)',
                    data: times.map((time, index) => [time.getTime(), ratioData[index]]),
                    color: '#28a745',
                    yAxis: 1
                }, {
                    name: '性能系数',
                    data: times.map((time, index) => [time.getTime(), copData[index]]),
                    color: '#fd7e14',
                    yAxis: 2
                }],
                exporting: {
                    enabled: true,
                    buttons: {
                        contextButton: {
                            menuItems: ['downloadPNG', 'downloadJPEG', 'downloadPDF', 'downloadSVG', 'separator', 'downloadCSV', 'downloadXLS']
                        }
                    }
                }
            });
        }

        // 生成系统能效指标数据
        function generateSystemEfficiencyData(startTime, endTime, granularity) {
            const data = [];
            const current = new Date(startTime);
            
            while (current <= endTime) {
                const hour = current.getHours();
                const dayOfWeek = current.getDay();
                
                // 时间因子（工作时间负荷更高）
                const timeFactor = (hour >= 8 && hour <= 18 && dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.2 : 0.8;
                
                // 季节因子
                const month = current.getMonth();
                const seasonFactor = (month >= 5 && month <= 8) ? 1.3 : 0.9; // 夏季负荷更高
                
                // 随机波动
                const randomFactor = 0.85 + Math.random() * 0.3;
                
                // 计算功率
                const basePower = 1000; // 基础功率
                const power = basePower * timeFactor * seasonFactor * randomFactor;
                
                // 计算占比
                const baseRatio = 20; // 基础占比
                const ratio = baseRatio + (Math.random() - 0.5) * 5;
                
                // 计算性能系数
                const baseCOP = 4.5; // 基础性能系数
                const cop = baseCOP + (Math.random() - 0.5) * 0.5;
                
                data.push({
                    time: new Date(current),
                    power: Math.round(power * 10) / 10,
                    ratio: Math.round(ratio * 10) / 10,
                    cop: Math.round(cop * 100) / 100
                });
                
                current.setTime(current.getTime() + granularity * 60 * 1000);
            }
            
            return data;
        }

        // 更新能效比图表
        function updateEERChart() {
            const startDate = document.getElementById('eer-start-date').value;
            const endDate = document.getElementById('eer-end-date').value;
            const granularity = parseInt(document.getElementById('eer-data-granularity').value);
            
            if (!startDate || !endDate) {
                alert('请选择时间范围');
                return;
            }
            
            const startTime = new Date(startDate);
            const endTime = new Date(endDate);
            
            if (startTime >= endTime) {
                alert('开始时间必须早于结束时间');
                return;
            }
            
            // 生成数据
            const data = generateEERData(startTime, endTime, granularity);
            
            // 准备图表数据
            const times = data.map(d => d.time);
            const eerData = data.map(d => d.eer);
            
            // 创建图表
            Highcharts.chart('eer-container', {
                chart: {
                    type: 'spline',
                    zoomType: 'x'
                },
                title: {
                    text: '能效比分析',
                    style: {
                        fontSize: '16px',
                        fontWeight: 'bold'
                    }
                },
                subtitle: {
                    text: '能效比趋势分析 - 点击拖拽可缩放'
                },
                xAxis: {
                    type: 'datetime',
                    title: {
                        text: '时间'
                    }
                },
                yAxis: {
                    title: {
                        text: '能效比 (COP)',
                        style: {
                            color: '#45b7d1'
                        }
                    },
                    labels: {
                        style: {
                            color: '#45b7d1'
                        }
                    },
                    opposite: false
                },
                tooltip: {
                    formatter: function() {
                        return '<b>' + Highcharts.dateFormat('%Y-%m-%d %H:%M', this.x) + '</b><br/>' +
                            '<span style="color:' + this.series.color + '">' + this.series.name + '</span>: <b>' + this.y + '</b><br/>';
                    }
                },
                legend: {
                    enabled: false
                },
                plotOptions: {
                    spline: {
                        marker: {
                            enabled: false,
                            states: {
                                hover: {
                                    enabled: true,
                        radius: 3
                    },
                    lineWidth: 2
                }
            },
            series: [{
                name: '预测负荷',
                color: '#45b7d1',
                data: (function() {
                    const data = [];
                    const now = new Date();
                    const startTime = new Date(now.getFullYear(), now.getMonth(), now.getDate(), 0, 0, 0); // 今日00:00开始
                    
                    // 生成72小时的数据点（每小时一个点）
                    for (let i = 0; i < 72; i++) {
                        const time = new Date(startTime.getTime() + i * 60 * 60 * 1000);
                        
                        // 模拟负荷预测：基础负荷 + 日周期变化 + 随机波动
                        const baseLoad = 7500; // 基础负荷7500kW
                        const hourOfDay = time.getHours();
                        const dayOfWeek = time.getDay();
                        
                        // 日周期变化（工作时间负荷更高）
                        let dailyCycle = 0;
                        if (hourOfDay >= 8 && hourOfDay <= 18) {
                            dailyCycle = 1500 * Math.sin((hourOfDay - 8) * Math.PI / 10); // 工作时间峰值
                        } else {
                            dailyCycle = 300 * Math.sin(hourOfDay * Math.PI / 12); // 夜间较低
                        }
                        
                        // 工作日vs周末差异
                        const weekdayFactor = (dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.0 : 0.7;
                        
                        // 随机波动
                        const randomVariation = (Math.random() - 0.5) * 800;
                        
                        // 季节性因子（夏季负荷更高）
                        const seasonalFactor = 1.1; // 假设夏季
                        
                        const predictedLoad = Math.round(
                            (baseLoad + dailyCycle) * weekdayFactor * seasonalFactor + randomVariation
                        );
                        
                        data.push([time.getTime(), Math.max(4000, predictedLoad)]); // 最小4000kW
                    }
                    
                    return data;
                })()
            }]
        });

        // 初始化图表
        updateCurrentTime();
        updatePowerGauge();
        updateEERGauge();
        updateLoadAnalysisChart();
        updateLoadForecastChart();
        updateAIOptimizationChart();
        updateComprehensiveEfficiencyChart();
        updateEnergySavingTrend();
        updatePowerTrendChart();
        updateEERTimeRangeInfo();
        updateEERSystemSelection();
        updateEERStatistics();
        updateEnergySavingData();
        updateCumulativePower();
        updateEERValue();
    });
</script>
</body></html>
