                            <div style="font-size: 0.85rem; color: #666;">平均功率(kW)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #28a745;" id="power-max-value">0</div>
                            <div style="font-size: 0.85rem; color: #666;">最大功率(kW)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #fd7e14;" id="power-min-value">0</div>
                            <div style="font-size: 0.85rem; color: #666;">最小功率(kW)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #6f42c1;" id="power-load-rate">0</div>
                            <div style="font-size: 0.85rem; color: #666;">负荷率(%)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #dc3545;" id="power-peak-times">0</div>
                            <div style="font-size: 0.85rem; color: #666;">峰值次数</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #17a2b8;" id="power-efficiency">0</div>
                            <div style="font-size: 0.85rem; color: #666;">能效比</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 瞬时制冷量趋势弹出框 -->
        <div id="cooling-capacity-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center;">
            <div style="background: white; border-radius: 12px; padding: 20px; width: 85%; max-width: 1000px; max-height: 85%; overflow-y: auto; position: relative;">
                <button onclick="closeCoolingCapacityModal()" style="position: absolute; top: 15px; right: 15px; background: #dc3545; color: white; border: none; border-radius: 50%; width: 30px; height: 30px; cursor: pointer; font-size: 16px; font-weight: bold;">×</button>
                
                <!-- 标题区域 -->
                <div style="text-align: center; margin-bottom: 20px;">
                    <h3 style="margin: 0; color: #333; font-size: 1.5rem;">瞬时制冷量趋势分析</h3>
                    <p style="color: #666; margin: 5px 0 0 0; font-size: 0.9rem;">实时制冷量变化监控与历史数据分析</p>
                </div>
                
                <!-- 查询条件区域 -->
                <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                    <!-- 系统选择区域 -->
                    <div style="margin-bottom: 15px; padding-bottom: 15px; border-bottom: 1px solid #dee2e6;">
                        <div style="display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                            <label style="font-weight: 500; color: #495057; margin-right: 10px;">🏢 监控系统:</label>
                            
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <input type="checkbox" id="cooling-system-room" checked onchange="updateCoolingSystemSelection()" style="margin: 0; transform: scale(1.2);">
                                <label for="cooling-system-room" style="margin: 0; cursor: pointer; padding: 4px 8px; border-radius: 4px; background: #e3f2fd; color: #1976d2; font-size: 0.9rem; font-weight: 500;">机房系统</label>
                            </div>
                            
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <input type="checkbox" id="cooling-system-low" checked onchange="updateCoolingSystemSelection()" style="margin: 0; transform: scale(1.2);">
                                <label for="cooling-system-low" style="margin: 0; cursor: pointer; padding: 4px 8px; border-radius: 4px; background: #e8f5e8; color: #388e3c; font-size: 0.9rem; font-weight: 500;">低温系统</label>
                            </div>
                            
                            <div style="display: flex; align-items: center; gap: 6px;">
                                <input type="checkbox" id="cooling-system-medium" checked onchange="updateCoolingSystemSelection()" style="margin: 0; transform: scale(1.2);">
                                <label for="cooling-system-medium" style="margin: 0; cursor: pointer; padding: 4px 8px; border-radius: 4px; background: #fff3e0; color: #f57c00; font-size: 0.9rem; font-weight: 500;">中温系统</label>
                            </div>
                            
                            <div style="margin-left: 15px; font-size: 0.85rem; color: #6c757d;">
                                <span id="cooling-selected-systems">已选择: 机房系统, 低温系统, 中温系统</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- 时间筛选区域 -->
                    <div style="display: flex; align-items: flex-start; gap: 20px; flex-wrap: wrap;">
                        <!-- 快速时间选择 -->
                        <div style="display: flex; flex-direction: column; gap: 8px;">
                            <label style="font-weight: 500; color: #495057; font-size: 0.9rem;">⚡ 快速选择:</label>
                            <div style="display: flex; gap: 6px; flex-wrap: wrap;">
                                <button onclick="setQuickTimeRange(1)" class="quick-time-btn" style="padding: 4px 8px; border: 1px solid #007bff; background: white; color: #007bff; border-radius: 4px; cursor: pointer; font-size: 0.8rem; transition: all 0.2s;">1小时</button>
                                <button onclick="setQuickTimeRange(6)" class="quick-time-btn" style="padding: 4px 8px; border: 1px solid #007bff; background: white; color: #007bff; border-radius: 4px; cursor: pointer; font-size: 0.8rem; transition: all 0.2s;">6小时</button>
                                <button onclick="setQuickTimeRange(24)" class="quick-time-btn active" style="padding: 4px 8px; border: 1px solid #007bff; background: #007bff; color: white; border-radius: 4px; cursor: pointer; font-size: 0.8rem; transition: all 0.2s;">24小时</button>
                                <button onclick="setQuickTimeRange(168)" class="quick-time-btn" style="padding: 4px 8px; border: 1px solid #007bff; background: white; color: #007bff; border-radius: 4px; cursor: pointer; font-size: 0.8rem; transition: all 0.2s;">7天</button>
                                <button onclick="setQuickTimeRange(720)" class="quick-time-btn" style="padding: 4px 8px; border: 1px solid #007bff; background: white; color: #007bff; border-radius: 4px; cursor: pointer; font-size: 0.8rem; transition: all 0.2s;">30天</button>
                            </div>
                        </div>
                        
                        <!-- 自定义时间选择器 -->
                        <div style="display: flex; flex-direction: column; gap: 8px;">
                            <label style="font-weight: 500; color: #495057; font-size: 0.9rem;">📅 自定义时间范围:</label>
                            <div style="display: flex; align-items: center; gap: 10px; flex-wrap: wrap;">
                                <div style="display: flex; flex-direction: column; gap: 4px;">
                                    <label style="font-size: 0.8rem; color: #6c757d;">开始时间</label>
                                    <input type="datetime-local" id="cooling-start-date" style="padding: 6px 8px; border: 1px solid #ced4da; border-radius: 4px; font-size: 0.9rem; min-width: 180px;" onchange="onCustomTimeChange()">
                                </div>
                                <div style="align-self: flex-end; padding: 6px 0; color: #6c757d;">至</div>
                                <div style="display: flex; flex-direction: column; gap: 4px;">
                                    <label style="font-size: 0.8rem; color: #6c757d;">结束时间</label>
                                    <input type="datetime-local" id="cooling-end-date" style="padding: 6px 8px; border: 1px solid #ced4da; border-radius: 4px; font-size: 0.9rem; min-width: 180px;" onchange="onCustomTimeChange()">
                                </div>
                                <div style="align-self: flex-end;">
                                    <button onclick="setCurrentTime()" style="background: #6c757d; color: white; border: none; padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">设为当前</button>
                                </div>
                            </div>
                            <div id="time-range-info" style="font-size: 0.75rem; color: #28a745; margin-top: 2px;"></div>
                        </div>
                        
                        <!-- 数据粒度和操作按钮 -->
                        <div style="display: flex; flex-direction: column; gap: 8px;">
                            <label style="font-weight: 500; color: #495057; font-size: 0.9rem;">📊 数据粒度:</label>
                            <div style="display: flex; align-items: center; gap: 10px;">
                                <select id="cooling-data-granularity" style="padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px; background: white; font-size: 0.9rem;" onchange="updateTimeRangeInfo()">
                                    <option value="1">每分钟</option>
                                    <option value="5">每5分钟</option>
                                    <option value="15" selected>每15分钟</option>
                                    <option value="60">每小时</option>
                                    <option value="1440">每天</option>
                                </select>
                                <button onclick="updateCoolingCapacityTrendChart()" style="background: #007bff; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: 0.9rem;">🔍 查询</button>
                                <button onclick="exportCoolingTrendData()" style="background: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 500; font-size: 0.9rem;">📊 导出</button>
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- 图表容器 -->
                <div id="cooling-capacity-trend-container" style="height: 450px; border: 1px solid #e9ecef; border-radius: 8px; background: white;"></div>
                
                <!-- 统计信息面板 -->
                <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-top: 20px;">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 15px;">
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #007bff;" id="cooling-avg-value">0</div>
                            <div style="font-size: 0.85rem; color: #666;">平均制冷量(kW)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #28a745;" id="cooling-max-value">0</div>
                            <div style="font-size: 0.85rem; color: #666;">最大制冷量(kW)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #fd7e14;" id="cooling-min-value">0</div>
                            <div style="font-size: 0.85rem; color: #666;">最小制冷量(kW)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #6f42c1;" id="cooling-load-rate">0</div>
                            <div style="font-size: 0.85rem; color: #666;">负荷率(%)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #dc3545;" id="cooling-peak-times">0</div>
                            <div style="font-size: 0.85rem; color: #666;">峰值次数</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #17a2b8;" id="cooling-stability">0</div>
                            <div style="font-size: 0.85rem; color: #666;">稳定性(%)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- 年度节能指标弹出框 -->
        <div id="annual-savings-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); z-index: 1000; align-items: center; justify-content: center;">
            <div style="background: white; border-radius: 12px; padding: 20px; width: 85%; max-width: 1000px; max-height: 85%; overflow-y: auto; position: relative;">
                <button onclick="closeAnnualSavingsModal()" style="position: absolute; top: 15px; right: 15px; background: #dc3545; color: white; border: none; border-radius: 50%; width: 30px; height: 30px; cursor: pointer; font-size: 16px; font-weight: bold;">×</button>
                
                <!-- 标题区域 -->
                <div style="text-align: center; margin-bottom: 20px;">
                    <h3 id="annual-modal-title" style="margin: 0; color: #333; font-size: 1.5rem;">年度节能指标趋势</h3>
                    <p style="color: #666; margin: 5px 0 0 0; font-size: 0.9rem;">AI优化系统效益分析</p>
                </div>
                
                <!-- 时间筛选区域 -->
                <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-bottom: 20px; display: flex; align-items: center; gap: 15px; flex-wrap: wrap;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <label style="font-weight: 500; color: #495057;">📅 时间范围:</label>
                        <select id="time-range-select" style="padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px; background: white;" onchange="toggleCustomDateRange()">
                            <option value="7">最近7天</option>
                            <option value="30" selected>最近30天</option>
                            <option value="90">最近90天</option>
                            <option value="365">最近1年</option>
                            <option value="custom">自定义</option>
                        </select>
                    </div>
                    
                    <div id="custom-date-range" style="display: none; align-items: center; gap: 8px;">
                        <label style="font-weight: 500; color: #495057;">从:</label>
                        <input type="date" id="start-date" style="padding: 6px; border: 1px solid #ced4da; border-radius: 4px;">
                        <label style="font-weight: 500; color: #495057;">到:</label>
                        <input type="date" id="end-date" style="padding: 6px; border: 1px solid #ced4da; border-radius: 4px;">
                    </div>
                    
                    <div style="display: flex; align-items: center; gap: 8px;">
                        <label style="font-weight: 500; color: #495057;">📊 数据粒度:</label>
                        <select id="data-granularity" style="padding: 6px 12px; border: 1px solid #ced4da; border-radius: 4px; background: white;">
                            <option value="daily" selected>按日</option>
                            <option value="weekly">按周</option>
                            <option value="monthly">按月</option>
                        </select>
                    </div>
                    
                    <button onclick="updateAnnualSavingsChart()" style="background: #007bff; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 500;">🔍 查询</button>
                    <button onclick="exportChartData()" style="background: #28a745; color: white; border: none; padding: 8px 16px; border-radius: 4px; cursor: pointer; font-weight: 500;">📊 导出</button>
                </div>
                
                <!-- 图表容器 -->
                <div id="annual-savings-chart-container" style="height: 450px; border: 1px solid #e9ecef; border-radius: 8px; background: white;"></div>
                
                <!-- 统计信息面板 -->
                <div style="background: #f8f9fa; padding: 15px; border-radius: 8px; margin-top: 20px;">
                    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 15px;">
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #28a745;" id="total-energy-saved">0</div>
                            <div style="font-size: 0.85rem; color: #666;">总节能量(MWh)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #007bff;" id="avg-efficiency-rate">0</div>
                            <div style="font-size: 0.85rem; color: #666;">平均节能率(%)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #fd7e14;" id="total-cost-saved">0</div>
                            <div style="font-size: 0.85rem; color: #666;">总节约费用(万元)</div>
                        </div>
                        <div style="text-align: center;">
                            <div style="font-size: 1.2rem; font-weight: 600; color: #6f42c1;" id="co2-reduction">0</div>
                            <div style="font-size: 0.85rem; color: #666;">减排CO₂(吨)</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="charts-grid">
            <div class="chart-container">
                <div class="chart-title">设备运行状态</div>
                <div class="equipment-list">
                    <div class="equipment-item">
                        <span>主制冷机组 #1</span>
                        <span><span class="status-indicator status-online"></span>正常运行</span>
                    </div>
                    <div class="equipment-item">
                        <span>主制冷机组 #2</span>
                        <span><span class="status-indicator status-online"></span>正常运行</span>
                    </div>
                    <div class="equipment-item">
                        <span>备用制冷机组</span>
                        <span><span class="status-indicator status-warning"></span>待机状态</span>
                    </div>
                    <div class="equipment-item">
                        <span>循环水泵 #1</span>
                        <span><span class="status-indicator status-online"></span>正常运行</span>
                    </div>
                    <div class="equipment-item">
                        <span>循环水泵 #2</span>
                        <span><span class="status-indicator status-online"></span>正常运行</span>
                    </div>
                    <div class="equipment-item">
                        <span>冷却塔风机</span>
                        <span><span class="status-indicator status-online"></span>正常运行</span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 更新当前时间
        function updateCurrentTime() {
            const now = new Date();
            const timeString = now.toLocaleTimeString('zh-CN', {
                hour12: false,
                hour: '2-digit',
                minute: '2-digit',
                second: '2-digit'
            });
            document.getElementById('current-time').textContent = timeString;
        }

        // 模拟天气数据更新
        function updateWeatherData() {
            const weatherConditions = ['晴朗', '多云', '阴天', '小雨'];
            const randomWeather = weatherConditions[Math.floor(Math.random() * weatherConditions.length)];
            document.getElementById('weather-condition').textContent = randomWeather;
            
            const dryBulbTemp = (25 + Math.random() * 5).toFixed(1);
            document.getElementById('dry-bulb-temp').textContent = dryBulbTemp + '°C';
            
            const wetBulbTemp = (20 + Math.random() * 4).toFixed(1);
            document.getElementById('wet-bulb-temp').textContent = wetBulbTemp + '°C';
            
            const enthalpy = (65 + Math.random() * 10).toFixed(1);
            document.getElementById('enthalpy').textContent = enthalpy + ' kJ/kg';
        }

        // 模拟EER数据更新
        function updateEERData() {
            const newEER = (2.8 + Math.random() * 1.0).toFixed(1); // 2.8-3.8范围
            
            let level = '';
            let color = '';
            if (newEER > 3.5) {
                level = '优秀水平';
                color = '#228B22';
            } else if (newEER > 3.0) {
                level = '良好水平';
                color = '#32CD32';
            } else if (newEER > 2.5) {
                level = '一般水平';
                color = '#FFA500';
            } else {
                level = '需要改进';
                color = '#FF4444';
            }
            
            // 计算位置百分比 (2.0-4.0范围映射到0%-100%)
            const position = ((parseFloat(newEER) - 2.0) / (4.0 - 2.0)) * 100;
            
            // 更新指示器位置
            const indicator = document.getElementById('eer-indicator');
            const valueDisplay = document.getElementById('eer-value-display');
            const currentValue = document.getElementById('current-eer-value');
            const currentLevel = document.getElementById('current-eer-level');
            
            if (indicator && valueDisplay && currentValue && currentLevel) {
                indicator.style.left = position + '%';
                valueDisplay.style.left = position + '%';
                valueDisplay.textContent = newEER;
                
                currentValue.textContent = newEER;
                currentValue.style.color = color;
                currentLevel.textContent = level;
                currentLevel.style.color = color;
            }
        }

        // 模拟制冷量数据更新
        function updateCoolingCapacity() {
            const newCapacity = Math.floor(12000 + Math.random() * 6000); // 12000-18000 kW范围
            const capacityChart = Highcharts.charts.find(chart => 
                chart && chart.renderTo.id === 'cooling-capacity-gauge'
            );
            
            if (capacityChart) {
                capacityChart.series[0].points[0].update(newCapacity);
            }
        }

        // 模拟功率数据更新
        function updatePower() {
            const newPower = Math.floor(800 + Math.random() * 800); // 800-1600 kW范围
            const powerChart = Highcharts.charts.find(chart => 
                chart && chart.renderTo.id === 'power-gauge'
            );
            
            if (powerChart) {
                powerChart.series[0].points[0].update(newPower);
            }
        }

        // 模拟EER数据更新
        function updateEERGauge() {
            const newEER = (2.8 + Math.random() * 1.5).toFixed(1); // 2.8-4.3范围
            const eerChart = Highcharts.charts.find(chart => 
                chart && chart.renderTo.id === 'eer-gauge'
            );
            
            if (eerChart) {
                eerChart.series[0].points[0].update(parseFloat(newEER));
            }
        }

        // 设备功率表数据模拟更新
        function updatePowerTable() {
            // 模拟制冷量（假设系统制冷量）
            const totalCoolingCapacity = 1650; // kW
            
            // 生成随机功率数据
            const chillerPower = Math.floor(280 + Math.random() * 80); // 280-360 kW
            const chilledPumpPower = Math.floor(70 + Math.random() * 30); // 70-100 kW
            const coolingPumpPower = Math.floor(35 + Math.random() * 20); // 35-55 kW
            const coolingTowerPower = Math.floor(30 + Math.random() * 20); // 30-50 kW
            
            const totalPower = chillerPower + chilledPumpPower + coolingPumpPower + coolingTowerPower;
            
            // 计算占比
            const chillerRatio = ((chillerPower / totalPower) * 100).toFixed(1);
            const chilledPumpRatio = ((chilledPumpPower / totalPower) * 100).toFixed(1);
            const coolingPumpRatio = ((coolingPumpPower / totalPower) * 100).toFixed(1);
            const coolingTowerRatio = ((coolingTowerPower / totalPower) * 100).toFixed(1);
            
            // 计算性能系数 (制冷量/功率)
            const chillerCOP = (totalCoolingCapacity / chillerPower).toFixed(1);
            const chilledPumpCOP = (totalCoolingCapacity / chilledPumpPower).toFixed(1);
            const coolingPumpCOP = (totalCoolingCapacity / coolingPumpPower).toFixed(1);
            const coolingTowerCOP = (totalCoolingCapacity / coolingTowerPower).toFixed(1);
            const systemCOP = (totalCoolingCapacity / totalPower).toFixed(1);
            
            // 更新表格数据
            document.getElementById('chiller-power').textContent = chillerPower;
            document.getElementById('chiller-ratio').textContent = chillerRatio + '%';
            document.getElementById('chiller-cop').textContent = chillerCOP;
            
            document.getElementById('chilled-pump-power').textContent = chilledPumpPower;
            document.getElementById('chilled-pump-ratio').textContent = chilledPumpRatio + '%';
            document.getElementById('chilled-pump-cop').textContent = chilledPumpCOP;
            
            document.getElementById('cooling-pump-power').textContent = coolingPumpPower;
            document.getElementById('cooling-pump-ratio').textContent = coolingPumpRatio + '%';
            document.getElementById('cooling-pump-cop').textContent = coolingPumpCOP;
            
            document.getElementById('cooling-tower-power').textContent = coolingTowerPower;
            document.getElementById('cooling-tower-ratio').textContent = coolingTowerRatio + '%';
            document.getElementById('cooling-tower-cop').textContent = coolingTowerCOP;
            
            document.getElementById('total-power').textContent = totalPower;
            document.getElementById('system-cop').textContent = systemCOP;
        }

        // 显示设备曲线图
        function showEquipmentChart(title, type) {
            document.getElementById('modal-chart-title').textContent = title + ' - 24小时趋势';
            document.getElementById('chart-modal').style.display = 'flex';
            
            // 生成24小时数据
            const hours = [];
            const data = [];
            
            for (let i = 0; i < 24; i++) {
                hours.push(String(i).padStart(2, '0') + ':00');
                
                let value;
                switch(type) {
                    case 'chiller-power':
                        value = 280 + Math.random() * 80 + Math.sin(i * Math.PI / 12) * 30;
                        break;
                    case 'chilled-pump-power':
                        value = 70 + Math.random() * 30 + Math.sin(i * Math.PI / 12) * 10;
                        break;
                    case 'cooling-pump-power':
                        value = 35 + Math.random() * 20 + Math.sin(i * Math.PI / 12) * 8;
                        break;
                    case 'cooling-tower-power':
                        value = 30 + Math.random() * 20 + Math.sin(i * Math.PI / 12) * 7;
                        break;
                    case 'chiller-ratio':
                        value = 60 + Math.random() * 10;
                        break;
                    case 'chilled-pump-ratio':
                        value = 15 + Math.random() * 5;
                        break;
                    case 'cooling-pump-ratio':
                        value = 8 + Math.random() * 3;
                        break;
                    case 'cooling-tower-ratio':
                        value = 7 + Math.random() * 3;
                        break;
                    case 'chiller-cop':
                        value = 4.5 + Math.random() * 1.5;
                        break;
                    case 'chilled-pump-cop':
                        value = 18 + Math.random() * 4;
                        break;
                    case 'cooling-pump-cop':
                        value = 35 + Math.random() * 8;
                        break;
                    case 'cooling-tower-cop':
                        value = 38 + Math.random() * 8;
                        break;
                    default:
                        value = Math.random() * 100;
                }
                data.push(Math.round(value * 10) / 10);
            }
            
            // 确定单位和颜色
            let unit = '';
            let color = '#45b7d1';
            if (type.includes('power')) {
                unit = ' kW';
                color = '#0d6efd';
            } else if (type.includes('ratio')) {
                unit = '%';
                color = '#198754';
            } else if (type.includes('cop')) {
                unit = '';
                color = '#fd7e14';
            }
            
            // 创建Highcharts图表
            Highcharts.chart('modal-chart-container', {
                chart: {
                    type: 'spline'
                },
                title: {
                    text: null
                },
                xAxis: {
                    categories: hours,
                    title: {
                        text: '时间'
                    }
                },
                yAxis: {
                    title: {
                        text: title + unit
                    }
                },
                tooltip: {
                    formatter: function() {
                        return '<b>' + this.x + '</b><br/>' + 
                               this.series.name + ': <b>' + this.y + unit + '</b>';
                    }
                },
                legend: {
                    enabled: false
                },
                plotOptions: {
                    spline: {
                        marker: {
                            enabled: true,
                            radius: 4
                        },
                        lineWidth: 3
                    }
                },
                series: [{
                    name: title,
                    data: data,
                    color: color
                }]
            });
        }

