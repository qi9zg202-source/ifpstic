        // 更新设备统计信息
        function updateEquipmentStatistics(powerData, ratioData, copData, timeData) {
            if (powerData.length === 0) return;
            
            const powers = powerData;
            const ratios = ratioData;
            const cops = copData;
            
            // 计算统计值
            const avgPower = powers.reduce((a, b) => a + b, 0) / powers.length;
            const maxPower = Math.max(...powers);
            const avgRatio = ratios.reduce((a, b) => a + b, 0) / ratios.length;
            const avgCOP = cops.reduce((a, b) => a + b, 0) / cops.length;
            
            // 找到峰值时间
            const maxIndex = powers.indexOf(maxPower);
            const peakTime = data[maxIndex].time;
            
            // 计算稳定性（变异系数的倒数）
            const powerStd = Math.sqrt(powers.reduce((sum, val) => sum + Math.pow(val - avgPower, 2), 0) / powers.length);
            const stability = Math.max(0, 100 - (powerStd / avgPower * 100));
            
            // 更新显示
            document.getElementById('equipment-avg-power').textContent = avgPower.toFixed(1);
            document.getElementById('equipment-max-power').textContent = maxPower.toFixed(1);
            document.getElementById('equipment-avg-ratio').textContent = avgRatio.toFixed(1);
            document.getElementById('equipment-avg-cop').textContent = avgCOP.toFixed(2);
            document.getElementById('equipment-peak-time').textContent = formatTime(peakTime);
            document.getElementById('equipment-stability').textContent = stability.toFixed(1);
        }

        // 导出设备多Y轴数据
        function exportEquipmentMultiAxisData() {
            const startDate = document.getElementById('equipment-start-date').value;
            const endDate = document.getElementById('equipment-end-date').value;
            const granularity = parseInt(document.getElementById('equipment-data-granularity').value);
            
            if (!startDate || !endDate) {
                alert('请先查询数据');
                return;
            }
            
            if (selectedEquipmentTypes.length === 0) {
                alert('请至少选择一种设备类型');
                return;
            }
            
            const startTime = new Date(startDate);
            const endTime = new Date(endDate);
            
            // 设备类型映射
            const equipmentTypeMapping = {
                '冰机': 'chiller',
                '冷冻泵': 'chilled-pump',
                '冷却泵': 'cooling-pump',
                '冷却塔': 'cooling-tower'
            };
            
            // 创建CSV内容头部
            let csvContent = '时间';
            selectedEquipmentTypes.forEach(equipmentName => {
                csvContent += `,${equipmentName}-功率(kW),${equipmentName}-占比(%),${equipmentName}-性能系数`;
            });
            csvContent += '\n';
            
            // 生成所有设备的数据
            const allEquipmentData = {};
            let timePoints = [];
            
            selectedEquipmentTypes.forEach(equipmentName => {
                const equipmentType = equipmentTypeMapping[equipmentName];
                const data = generateEquipmentMultiAxisData(equipmentType, startTime, endTime, granularity);
                allEquipmentData[equipmentName] = data;
                if (timePoints.length === 0) {
                    timePoints = data.map(d => d.time);
                }
            });
            
            // 按时间点组织数据
            timePoints.forEach((time, index) => {
                let row = formatDateTime(time);
                selectedEquipmentTypes.forEach(equipmentName => {
                    const data = allEquipmentData[equipmentName][index];
                    row += `,${data.power},${data.ratio},${data.cop}`;
                });
                csvContent += row + '\n';
            });
            
            // 下载文件
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            const fileName = `设备功率分析_${selectedEquipmentTypes.join('_')}_${formatDate(startTime)}_${formatDate(endTime)}.csv`;
            link.setAttribute('download', fileName);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

