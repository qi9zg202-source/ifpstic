        // 生成综合能效指标数据
        function generateComprehensiveEfficiencyData(startTime, endTime, granularity) {
            const data = [];
            const current = new Date(startTime);
            
            while (current <= endTime) {
                const hour = current.getHours();
                const dayOfWeek = current.getDay();
                
                // 时间因子（工作时间负荷更高）
                const timeFactor = (hour >= 8 && hour <= 18 && dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.2 : 0.8;
                
                // 季节因子
                const month = current.getMonth();
                const seasonFactor = (month >= 5 && month <= 8) ? 1.3 : 0.9; // 夏季负荷更高
                
                // 随机波动
                const randomFactor = 0.85 + Math.random() * 0.3;
                
                // 计算功率
                const basePower = 1000; // 基础功率
                const power = basePower * timeFactor * seasonFactor * randomFactor;
                
                // 计算占比
                const baseRatio = 20; // 基础占比
                const ratio = baseRatio + (Math.random() - 0.5) * 5;
                
                // 计算性能系数
                const baseCOP = 4.5; // 基础性能系数
                const cop = baseCOP + (Math.random() - 0.5) * 0.5;
                
                data.push({
                    time: new Date(current),
                    power: Math.round(power * 10) / 10,
                    ratio: Math.round(ratio * 10) / 10,
                    cop: Math.round(cop * 100) / 100
                });
                
                current.setTime(current.getTime() + granularity * 60 * 1000);
            }
            
            return data;
        }

        // 更新设备多Y轴图表
        function updateEquipmentMultiAxisChart() {
            const startDate = document.getElementById('equipment-start-date').value;
            const endDate = document.getElementById('equipment-end-date').value;
            const granularity = parseInt(document.getElementById('equipment-data-granularity').value);
            
            if (!startDate || !endDate) {
                alert('请选择时间范围');
                return;
            }
            
            const startTime = new Date(startDate);
            const endTime = new Date(endDate);
            
            if (startTime >= endTime) {
                alert('开始时间必须早于结束时间');
                return;
            }
            
            if (selectedEquipmentTypes.length === 0) {
                alert('请至少选择一种设备类型');
                return;
            }
            
            // 设备类型映射
            const equipmentTypeMapping = {
                '冰机': 'chiller',
                '冷冻泵': 'chilled-pump',
                '冷却泵': 'cooling-pump',
                '冷却塔': 'cooling-tower'
            };
            
            // 设备颜色映射
            const equipmentColors = {
                '冰机': ['#1976d2', '#1565c0', '#0d47a1'],
                '冷冻泵': ['#388e3c', '#2e7d32', '#1b5e20'],
                '冷却泵': ['#f57c00', '#ef6c00', '#e65100'],
                '冷却塔': ['#7b1fa2', '#6a1b9a', '#4a148c']
            };
            
            // 为每个选中的设备类型生成数据
            const allSeries = [];
            let allTimes = [];
            let totalPowerData = [];
            let totalRatioData = [];
            let totalCopData = [];
            
            selectedEquipmentTypes.forEach((equipmentName, index) => {
                const equipmentType = equipmentTypeMapping[equipmentName];
                const data = generateEquipmentMultiAxisData(equipmentType, startTime, endTime, granularity);
                const colors = equipmentColors[equipmentName];
                
                if (index === 0) {
                    allTimes = data.map(d => d.time);
                    totalPowerData = data.map(d => d.power);
                    totalRatioData = data.map(d => d.ratio);
                    totalCopData = data.map(d => d.cop);
                } else {
                    // 累加数据用于统计
                    data.forEach((item, i) => {
                        if (i < totalPowerData.length) {
                            totalPowerData[i] += item.power;
                            totalRatioData[i] += item.ratio;
                            totalCopData[i] = (totalCopData[i] + item.cop) / 2; // 性能系数取平均
                        }
                    });
                }
                
                // 添加功率系列
                allSeries.push({
                    name: `${equipmentName}-功率(kW)`,
                    data: data.map(d => [d.time.getTime(), d.power]),
                    color: colors[0],
                    yAxis: 0,
                    dashStyle: 'Solid'
                });
                
                // 添加占比系列
                allSeries.push({
                    name: `${equipmentName}-占比(%)`,
                    data: data.map(d => [d.time.getTime(), d.ratio]),
                    color: colors[1],
                    yAxis: 1,
                    dashStyle: 'ShortDash'
                });
                
                // 添加性能系数系列
                allSeries.push({
                    name: `${equipmentName}-性能系数`,
                    data: data.map(d => [d.time.getTime(), d.cop]),
                    color: colors[2],
                    yAxis: 2,
                    dashStyle: 'Dot'
                });
            });
            
            // 创建多Y轴图表
            Highcharts.chart('equipment-multi-axis-container', {
                chart: {
                    type: 'spline',
                    zoomType: 'x'
                },
                title: {
                    text: `设备功率分析 - ${selectedEquipmentTypes.join(', ')}`,
                    style: {
                        fontSize: '16px',
                        fontWeight: 'bold'
                    }
                },
                subtitle: {
                    text: '点击拖拽可缩放查看详细数据 | 实线:功率 虚线:占比 点线:性能系数'
                },
                xAxis: {
                    type: 'datetime',
                    title: {
                        text: '时间'
                    }
                },
                yAxis: [{
                    // 第一个Y轴 - 功率
                    title: {
                        text: '功率 (kW)',
                        style: {
