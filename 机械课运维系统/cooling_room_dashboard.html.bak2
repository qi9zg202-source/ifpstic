        // 根据设备名称自动选中对应的设备类型
        function selectEquipmentTypeByName(equipmentName) {
            const typeMapping = {
                '冰机': 'equipment-type-chiller',
                '冷冻泵': 'equipment-type-chilled-pump', 
                '冷却泵': 'equipment-type-cooling-pump',
                '冷却塔': 'equipment-type-cooling-tower'
            };
            
            const checkboxId = typeMapping[equipmentName];
            if (checkboxId) {
                document.getElementById(checkboxId).checked = true;
                selectedEquipmentTypes = [equipmentName];
                updateEquipmentTypeSelection();
            }
        }
