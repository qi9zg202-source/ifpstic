                    opposite: true
                }, {
                    // 第三个Y轴 - 能效比EER
                    title: {
                        text: '能效比EER',
                        style: {
                            color: '#28a745'
                        }
                    },
                    labels: {
                        style: {
                            color: '#28a745'
                        }
                    },
                    opposite: true,
                    offset: 60,
                    min: 2,
                    max: 5
                }],
                tooltip: {
                    shared: true,
                    formatter: function() {
                        let tooltip = '<b>' + Highcharts.dateFormat('%Y-%m-%d %H:%M', this.x) + '</b><br/>';
                        this.points.forEach(function(point) {
                            let unit = '';
                            if (point.series.name.includes('制冷量')) unit = ' GJ';
                            else if (point.series.name.includes('电量')) unit = ' kWh';
                            tooltip += '<span style="color:' + point.color + '">' + point.series.name + '</span>: <b>' + point.y + unit + '</b><br/>';
                        });
                        return tooltip;
                    }
                },
                legend: {
                    enabled: true,
                    align: 'center',
                    verticalAlign: 'bottom'
                },
                plotOptions: {
                    spline: {
                        marker: {
                            enabled: false,
                            states: {
                                hover: {
                                    enabled: true,
                                    radius: 5
                                }
                            }
                        },
                        lineWidth: 2
                    }
                },
                series: [{
                    name: '累计制冷量(GJ)',
                    data: times.map((time, index) => [time.getTime(), coolingData[index]]),
                    color: '#007bff',
                    yAxis: 0
                }, {
                    name: '累计电量(kWh)',
                    data: times.map((time, index) => [time.getTime(), powerData[index]]),
                    color: '#dc3545',
                    yAxis: 1
                }, {
                    name: '能效比EER',
                    data: times.map((time, index) => [time.getTime(), eerData[index]]),
                    color: '#28a745',
                    yAxis: 2
                }],
                exporting: {
                    enabled: true,
                    buttons: {
                        contextButton: {
                            menuItems: ['downloadPNG', 'downloadJPEG', 'downloadPDF', 'downloadSVG', 'separator', 'downloadCSV', 'downloadXLS']
                        }
                    }
                }
            });
            
            // 更新统计信息
            updateComprehensiveStatistics(data);
        }

        // 更新综合能效统计信息
        function updateComprehensiveStatistics(data) {
            if (data.length === 0) return;
            
            const coolingValues = data.map(d => d.cumulativeCooling);
            const powerValues = data.map(d => d.cumulativePower);
            const eerValues = data.map(d => d.eer);
            
            // 计算统计值
            const totalCooling = Math.max(...coolingValues) - Math.min(...coolingValues);
            const totalPower = Math.max(...powerValues) - Math.min(...powerValues);
            const avgEER = eerValues.reduce((a, b) => a + b, 0) / eerValues.length;
            
            // 计算能效趋势（最后25%与前25%的EER对比）
            const quarterLength = Math.floor(eerValues.length / 4);
            const firstQuarterAvg = eerValues.slice(0, quarterLength).reduce((a, b) => a + b, 0) / quarterLength;
            const lastQuarterAvg = eerValues.slice(-quarterLength).reduce((a, b) => a + b, 0) / quarterLength;
            const efficiencyTrend = ((lastQuarterAvg - firstQuarterAvg) / firstQuarterAvg * 100);
            
            // 找到EER峰值时间
            const maxEERIndex = eerValues.indexOf(Math.max(...eerValues));
            const peakTime = data[maxEERIndex].time;
            
            // 计算节能量（假设基准EER为3.0）
            const baselineEER = 3.0;
            const energySaved = totalPower * (1 - baselineEER / avgEER);
            
            // 更新显示
            document.getElementById('comprehensive-total-cooling').textContent = totalCooling.toFixed(1);
            document.getElementById('comprehensive-total-power').textContent = totalPower.toLocaleString();
            document.getElementById('comprehensive-avg-eer').textContent = avgEER.toFixed(2);
            document.getElementById('comprehensive-efficiency-trend').textContent = (efficiencyTrend >= 0 ? '+' : '') + efficiencyTrend.toFixed(1);
            document.getElementById('comprehensive-peak-time').textContent = formatTime(peakTime);
            document.getElementById('comprehensive-energy-saved').textContent = Math.max(0, energySaved).toFixed(0);
            
            // 根据趋势设置颜色
            const trendElement = document.getElementById('comprehensive-efficiency-trend');
            if (efficiencyTrend > 0) {
                trendElement.style.color = '#28a745';
            } else if (efficiencyTrend < -2) {
                trendElement.style.color = '#dc3545';
            } else {
                trendElement.style.color = '#ffc107';
            }
        }

        // 导出综合能效指标数据
        function exportComprehensiveEfficiencyData() {
            const startDate = document.getElementById('comprehensive-start-date').value;
            const endDate = document.getElementById('comprehensive-end-date').value;
            const granularity = parseInt(document.getElementById('comprehensive-data-granularity').value);
            
            if (!startDate || !endDate) {
                alert('请先查询数据');
                return;
            }
            
            const startTime = new Date(startDate);
            const endTime = new Date(endDate);
            const data = generateComprehensiveEfficiencyData(startTime, endTime, granularity);
            
            // 创建CSV内容
            let csvContent = `时间,累计制冷量(GJ),累计电量(kWh),能效比EER\n`;
            data.forEach(row => {
                csvContent += `${formatDateTime(row.time)},${row.cumulativeCooling},${row.cumulativePower},${row.eer}\n`;
            });
            
            // 下载文件
            const blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            const link = document.createElement('a');
            const url = URL.createObjectURL(blob);
            link.setAttribute('href', url);
            link.setAttribute('download', `综合能效指标数据_${formatDate(startTime)}_${formatDate(endTime)}.csv`);
            link.style.visibility = 'hidden';
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        // 节能分析趋势弹出框相关函数
        // 显示节能分析趋势
        function showEnergySavingTrend() {
            document.getElementById('energy-saving-modal').style.display = 'flex';
            
            // 设置默认时间范围（30天）
            const now = new Date();
            const monthAgo = new Date(now.getTime() - 30 * 24 * 60 * 60 * 1000);
            
            document.getElementById('energy-saving-start-date').value = formatDateTimeLocal(monthAgo);
            document.getElementById('energy-saving-end-date').value = formatDateTimeLocal(now);
            
            // 更新时间范围信息
            updateEnergySavingTimeRangeInfo();
            
            // 生成初始图表
            updateEnergySavingChart();
        }

        // 关闭节能分析弹出框
        function closeEnergySavingModal() {
            document.getElementById('energy-saving-modal').style.display = 'none';
        }

        // 设置快速时间范围
        function setEnergySavingQuickTimeRange(days) {
            const now = new Date();
            const startTime = new Date(now.getTime() - days * 24 * 60 * 60 * 1000);
            
            document.getElementById('energy-saving-start-date').value = formatDateTimeLocal(startTime);
            document.getElementById('energy-saving-end-date').value = formatDateTimeLocal(now);
            
            // 更新按钮状态
            document.querySelectorAll('.energy-saving-quick-time-btn').forEach(btn => {
                btn.classList.remove('active');
                btn.style.background = 'white';
                btn.style.color = '#28a745';
            });
            
            event.target.classList.add('active');
            event.target.style.background = '#28a745';
            event.target.style.color = 'white';
            
            updateEnergySavingTimeRangeInfo();
        }

        // 设置当前时间
        function setEnergySavingCurrentTime() {
            const now = new Date();
            document.getElementById('energy-saving-end-date').value = formatDateTimeLocal(now);
            updateEnergySavingTimeRangeInfo();
        }

        // 自定义时间变化处理
        function onEnergySavingCustomTimeChange() {
            // 清除快速选择按钮的激活状态
            document.querySelectorAll('.energy-saving-quick-time-btn').forEach(btn => {
                btn.classList.remove('active');
                btn.style.background = 'white';
                btn.style.color = '#28a745';
            });
            
            updateEnergySavingTimeRangeInfo();
        }

        // 更新时间范围信息
        function updateEnergySavingTimeRangeInfo() {
            const startDate = document.getElementById('energy-saving-start-date').value;
            const endDate = document.getElementById('energy-saving-end-date').value;
            const granularity = parseInt(document.getElementById('energy-saving-data-granularity').value);
            
            if (startDate && endDate) {
                const start = new Date(startDate);
                const end = new Date(endDate);
                const diffMs = end - start;
                const diffDays = Math.round(diffMs / (1000 * 60 * 60 * 24) * 10) / 10;
                
                const dataPoints = Math.ceil(diffMs / (granularity * 60 * 1000));
                
                let timeSpanText = `${diffDays}天`;
                
                let infoText = `时间跨度: ${timeSpanText}, 预计数据点: ${dataPoints}个`;
                let infoColor = '#28a745';
                
                if (dataPoints > 500) {
                    infoText += ' (数据量较大，建议调整粒度)';
                    infoColor = '#ffc107';
                }
                if (dataPoints > 1000) {
                    infoText += ' ⚠️';
                    infoColor = '#dc3545';
                }
                
                const infoElement = document.getElementById('energy-saving-time-range-info');
                infoElement.textContent = infoText;
                infoElement.style.color = infoColor;
            }
        }

