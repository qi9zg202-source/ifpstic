        // 生成负荷预测数据
        function generateLoadForecastData(startTime, endTime, granularity) {
            const data = [];
            const current = new Date(startTime);
            
            while (current <= endTime) {
                const hour = current.getHours();
                const dayOfWeek = current.getDay();
                
                // 时间因子（工作时间负荷更高）
                const timeFactor = (hour >= 8 && hour <= 18 && dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.2 : 0.8;
                
                // 季节因子
                const month = current.getMonth();
                const seasonFactor = (month >= 5 && month <= 8) ? 1.3 : 0.9; // 夏季负荷更高
                
                // 随机波动
                const randomFactor = 0.85 + Math.random() * 0.3;
                
                // 计算负荷
                const baseLoad = 7500; // 基础负荷
                const load = baseLoad * timeFactor * seasonFactor * randomFactor;
                
                data.push({
                    time: new Date(current),
                    predictedLoad: Math.round(load * 10) / 10
                });
                
                current.setTime(current.getTime() + granularity * 60 * 1000);
            }
            
            return data;
        }

