        // 更新负荷预测图表
        function updateLoadForecastChart() {
            const startDate = document.getElementById('load-forecast-start-date').value;
            const endDate = document.getElementById('load-forecast-end-date').value;
            const granularity = parseInt(document.getElementById('load-forecast-data-granularity').value);
            
            if (!startDate || !endDate) {
                alert('请选择时间范围');
                return;
            }
            
            const startTime = new Date(startDate);
            const endTime = new Date(endDate);
            
            if (startTime >= endTime) {
                alert('开始时间必须早于结束时间');
                return;
            }
            
            // 生成数据
            const data = generateLoadForecastData(startTime, endTime, granularity);
            
            // 准备图表数据
            const times = data.map(d => d.time);
            const predictedLoad = data.map(d => d.predictedLoad);
            
            // 创建图表
            Highcharts.chart('load-forecast-container', {
                chart: {
                    type: 'spline',
                    zoomType: 'x'
                },
                title: {
                    text: '高效机房负荷预测',
                    style: {
                        fontSize: '16px',
                        fontWeight: 'bold'
                    }
                },
                subtitle: {
                    text: '预测负荷趋势分析 - 点击拖拽可缩放'
                },
                xAxis: {
                    type: 'datetime',
                    title: {
                        text: '时间'
                    }
                },
                yAxis: {
                    title: {
                        text: '负荷 (kW)',
                        style: {
                            color: '#45b7d1'
                        }
                    },
                    labels: {
                        style: {
                            color: '#45b7d1'
                        }
                    },
                    opposite: false
                },
                tooltip: {
                    formatter: function() {
                        return '<b>' + Highcharts.dateFormat('%Y-%m-%d %H:%M', this.x) + '</b><br/>' +
                            '<span style="color:' + this.series.color + '">' + this.series.name + '</span>: <b>' + this.y + ' kW</b><br/>';
                    }
                },
                legend: {
                    enabled: false
                },
                plotOptions: {
                    spline: {
                        marker: {
                            enabled: false,
                            states: {
                                hover: {
                                    enabled: true,
                                    radius: 5
                                }
                            }
                        },
                        lineWidth: 2
                    }
                },
                series: [{
                    name: '预测负荷',
                    data: times.map((time, index) => [time.getTime(), predictedLoad[index]]),
                    color: '#45b7d1'
                }],
                exporting: {
                    enabled: true,
                    buttons: {
                        contextButton: {
                            menuItems: ['downloadPNG', 'downloadJPEG', 'downloadPDF', 'downloadSVG', 'separator', 'downloadCSV', 'downloadXLS']
                        }
                    }
                }
            });
        }

        // 生成负荷预测数据
        function generateLoadForecastData(startTime, endTime, granularity) {
            const data = [];
            const current = new Date(startTime);
            
            while (current <= endTime) {
                const hour = current.getHours();
                const dayOfWeek = current.getDay();
                
                // 时间因子（工作时间负荷更高）
                const timeFactor = (hour >= 8 && hour <= 18 && dayOfWeek >= 1 && dayOfWeek <= 5) ? 1.2 : 0.8;
                
                // 季节因子
                const month = current.getMonth();
                const seasonFactor = (month >= 5 && month <= 8) ? 1.3 : 0.9; // 夏季负荷更高
                
                // 随机波动
                const randomFactor = 0.85 + Math.random() * 0.3;
                
                // 计算负荷
                const baseLoad = 7500; // 基础负荷
                const load = baseLoad * timeFactor * seasonFactor * randomFactor;
                
                data.push({
                    time: new Date(current),
                    predictedLoad: Math.round(load * 10) / 10
                });
                
                current.setTime(current.getTime() + granularity * 60 * 1000);
            }
            
            return data;
        }

        // 更新综合能效指标图表
